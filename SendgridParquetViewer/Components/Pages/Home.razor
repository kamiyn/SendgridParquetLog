@page "/"
@rendermode InteractiveServer
@attribute [Authorize]
@implements IAsyncDisposable
@using System
@using System.Collections.Generic
@using System.Globalization
@using System.IO
@using System.Linq
@using System.Threading
@using System.Threading.Tasks
@using System.Text.Json
@using Microsoft.AspNetCore.Components
@using Microsoft.Extensions.Options
@using Microsoft.JSInterop
@using SendgridParquet.Shared
@using SendgridParquetViewer.Configuration
@using SendgridParquetViewer.Models
@inject IJSRuntime JsRuntime
@inject TimeProvider TimeProvider
@inject ILogger<Home> Logger
@inject IOptionsSnapshot<DuckDbWasmOptions> DuckDbOptions
@inject S3StorageService S3StorageService

<PageTitle>SendGrid Events Viewer</PageTitle>

<h1>SendGrid Events Viewer</h1>

<div style="padding: 20px; background-color: #f8f9fa; border-radius: 8px; margin-bottom: 20px;">
	<h3>検索条件</h3>

	<FluentStack Orientation="Orientation.Horizontal" Wrap="true" Style="gap: 20px; align-items: flex-start;">
		<div style="min-width: 250px;">
			<FluentTextField @bind-Value="_selectedEmail" @oninput="OnInputChange" Label="email（LIKE句）" Style="width: 100%;" Placeholder="example@domain.com" />
		</div>

		<div style="min-width: 250px;">
			<FluentTextField @bind-Value="_selectedSgTemplateId" @oninput="OnInputChange" Label="sg_template_id（完全一致）" Style="width: 100%;" Placeholder="d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx" />
		</div>

		<div style="min-width: 200px;">
			<FluentLabel>イベントタイプ</FluentLabel>
			<FluentSelect TOption="string" @bind-Value="_selectedEventType" @onchange="OnEventTypeChange" Style="width: 100%; margin-top: 5px;">
				@foreach (var eventType in SendGridEventTypes.AllEventTypes)
				{
					<FluentOption TOption="string" Value="@eventType.Value">@eventType.Display</FluentOption>
				}
			</FluentSelect>
		</div>

		<div style="min-width: 260px;">
			<FluentLabel>対象年月</FluentLabel>
			<FluentStack Orientation="Orientation.Horizontal" Style="gap: 8px; align-items: center;">
				<FluentButton Appearance="Appearance.Neutral" Disabled="@_isDownloading" OnClick="@(async () => await ChangeMonthAsync(-1))">前月</FluentButton>
				<FluentDatePicker @bind-Value="CurrentMonthDate" @bind-Value:after="OnMonthPickerAfterChanged" Style="width: 160px;" />
				<FluentButton Appearance="Appearance.Neutral" Disabled="@_isDownloading" OnClick="@(async () => await ChangeMonthAsync(1))">翌月</FluentButton>
			</FluentStack>
			<small style="color: #666; display: block; margin-top: 4px;">月を変更するとその月のParquetを自動取得します</small>
		</div>

		<div style="margin-top: 25px;">
			<FluentButton Appearance="Appearance.Accent" Disabled="@_isDownloading" OnClick="@(async () => await EnsureMonthDataAsync())">月データ取得</FluentButton>
		</div>

		<div style="margin-top: 25px;">
			<FluentButton Appearance="Appearance.Neutral" Disabled="@(_isLoading || _isDownloading || !_selectedDay.HasValue)" OnClick="@(async () => await SearchAsync())">検索</FluentButton>
		</div>
	</FluentStack>
</div>

@if (!string.IsNullOrEmpty(_errorMessage))
{
	<FluentMessageBar Intent="MessageIntent.Error" Style="margin-bottom: 20px;">
		<div>
			<strong>エラー:</strong> @_errorMessage
		</div>
	</FluentMessageBar>
}

@if (_isDownloading)
{
	<FluentProgress />
	<p>月データをダウンロード中です...</p>
}
else if (_manifestLoaded)
{
	<div style="margin-bottom: 10px; display: flex; gap: 16px; flex-wrap: wrap; align-items: center;">
		<span>ダウンロード済み日数: @_downloadedDays.Count / @_availableDays.Count</span>
		@if (_selectedDay.HasValue)
		{
			<span>選択中の日付: @_selectedDay.Value 日</span>
		}
	</div>

	<div class="calendar-container">
		<table class="calendar-table">
			<thead>
				<tr>
					<th>日</th>
					<th>月</th>
					<th>火</th>
					<th>水</th>
					<th>木</th>
					<th>金</th>
					<th>土</th>
				</tr>
			</thead>
			<tbody>
				@foreach (var week in _calendarWeeks)
				{
					<tr>
						@foreach (var date in week)
						{
							if (date is null)
							{
								<td class="calendar-day empty"></td>
							}
							else
							{
								bool hasData = _downloadedDays.Contains(date.Value.Day);
								bool available = _availableDays.Contains(date.Value.Day);
								bool selected = _selectedDay == date.Value.Day;
								string buttonClass = GetCalendarButtonClass(hasData, available, selected);
								bool disabled = !available || _isLoading || _isDownloading;

								<td class="calendar-day">
									<button class="@buttonClass" disabled="@disabled" @onclick="@(async () => await OnDaySelectedAsync(date.Value.Day))">
										@date.Value.Day
									</button>
								</td>
							}
						}
					</tr>
				}
			</tbody>
		</table>
	</div>
}
else
{
	<p>月データを読み込んでください。</p>
}

@if (_isLoading)
{
	<FluentProgress />
	<p>データを検索中...</p>
}
else
{
	@if (_hasSearched)
	{
		<div style="margin-top: 10px;">
			<p>検索結果: @_sendGridEvents.Length 件</p>
		</div>
	}

	private async Task ClearRenderedResultsAsync()
	{
		if (_duckDbInterop is null || string.IsNullOrEmpty(_resultsHost.Id))
		{
			return;
		}

		try
		{
			await _duckDbInterop.InvokeVoidAsync("clearResults", _resultsHost);
		}
		catch (JSException ex)
		{
			Logger.LogWarning(ex, "Failed to clear duckdb results");
		}
	}

	private static string? NormalizeFilterValue(string? raw)
	{
		return string.IsNullOrWhiteSpace(raw) ? null : raw.Trim();
	}

	private static string? NormalizeExactValue(string? raw) => NormalizeFilterValue(raw);

	private static string[] ExtractColumns(JsonElement root)
	{
		if (!root.TryGetProperty("columns", out var columnsElement) || columnsElement.ValueKind != JsonValueKind.Array)
		{
			return Array.Empty<string>();
		}

		var length = columnsElement.GetArrayLength();
		if (length == 0)
		{
			return Array.Empty<string>();
		}

		var columns = new string[length];
		var index = 0;
		foreach (var columnElement in columnsElement.EnumerateArray())
		{
			columns[index++] = columnElement.ValueKind == JsonValueKind.String
				? columnElement.GetString() ?? string.Empty
				: columnElement.ToString();
		}

		return columns;
	}

	private static string[][] ExtractRowValues(JsonElement root, int expectedColumnCount)
	{
		if (!root.TryGetProperty("rows", out var rowsElement) || rowsElement.ValueKind != JsonValueKind.Array)
		{
			return Array.Empty<string[]>();
		}

		var totalRows = rowsElement.GetArrayLength();
		if (totalRows == 0)
		{
			return Array.Empty<string[]>();
		}

		var rows = new string[totalRows][];
		var index = 0;
		foreach (var rowElement in rowsElement.EnumerateArray())
		{
			if (rowElement.ValueKind != JsonValueKind.Object || !rowElement.TryGetProperty("values", out var valuesElement))
			{
				rows[index++] = Array.Empty<string>();
				continue;
			}

			rows[index++] = ExtractValueArray(valuesElement, expectedColumnCount);
		}

		return rows;
	}

	private static string[] ExtractValueArray(JsonElement valuesElement, int expectedColumnCount)
	{
		if (valuesElement.ValueKind != JsonValueKind.Array)
		{
			return Array.Empty<string>();
		}

		var targetLength = expectedColumnCount > 0 ? expectedColumnCount : valuesElement.GetArrayLength();
		if (targetLength <= 0)
		{
			return Array.Empty<string>();
		}

		var values = new string[targetLength];
		var index = 0;
		foreach (var valueElement in valuesElement.EnumerateArray())
		{
			if (index >= targetLength)
			{
				break;
			}

			values[index++] = ToDisplayString(valueElement);
		}

		for (; index < targetLength; index++)
		{
			values[index] = string.Empty;
		}

		return values;
	}

	private static string ToDisplayString(JsonElement element)
	{
		return element.ValueKind switch
		{
			JsonValueKind.Null => string.Empty,
			JsonValueKind.String => element.GetString() ?? string.Empty,
			JsonValueKind.True => bool.TrueString,
			JsonValueKind.False => bool.FalseString,
			JsonValueKind.Number => element.ToString(),
			JsonValueKind.Object => element.ToString(),
			JsonValueKind.Array => element.ToString(),
			_ => element.ToString()
		};
	}

	private static SendGridEventParquet[] ConvertToSendGridEvents(JsonElement? result)
	{
		if (result is null)
		{
			return Array.Empty<SendGridEventParquet>();
		}

		var root = result.Value;
		if (root.ValueKind is JsonValueKind.Null or JsonValueKind.Undefined)
		{
			return Array.Empty<SendGridEventParquet>();
		}

		var columns = ExtractColumns(root);
		var rowValues = ExtractRowValues(root, columns.Length);
		if (columns.Length == 0 || rowValues.Length == 0)
		{
			return Array.Empty<SendGridEventParquet>();
		}

		var columnIndexMap = BuildColumnIndexMap(columns);
		if (columnIndexMap.Count == 0)
		{
			return Array.Empty<SendGridEventParquet>();
		}

		var events = new SendGridEventParquet[rowValues.Length];

		for (var i = 0; i < rowValues.Length; i++)
		{
			var values = rowValues[i];
			events[i] = new SendGridEventParquet
			{
				Email = GetStringValue(columnIndexMap, values, nameof(SendGridEventParquet.Email)),
				Timestamp = GetInt64Value(columnIndexMap, values, nameof(SendGridEventParquet.Timestamp)),
				Event = GetStringValue(columnIndexMap, values, nameof(SendGridEventParquet.Event)),
				Category = GetStringValue(columnIndexMap, values, nameof(SendGridEventParquet.Category)),
				SgEventId = GetStringValue(columnIndexMap, values, nameof(SendGridEventParquet.SgEventId)),
				SgMessageId = GetStringValue(columnIndexMap, values, nameof(SendGridEventParquet.SgMessageId)),
				SgTemplateId = GetStringValue(columnIndexMap, values, nameof(SendGridEventParquet.SgTemplateId)),
				UserAgent = GetStringValue(columnIndexMap, values, nameof(SendGridEventParquet.UserAgent)),
				Ip = GetStringValue(columnIndexMap, values, nameof(SendGridEventParquet.Ip)),
				Url = GetStringValue(columnIndexMap, values, nameof(SendGridEventParquet.Url)),
				Reason = GetStringValue(columnIndexMap, values, nameof(SendGridEventParquet.Reason)),
				Status = GetStringValue(columnIndexMap, values, nameof(SendGridEventParquet.Status)),
				Response = GetStringValue(columnIndexMap, values, nameof(SendGridEventParquet.Response)),
				Attempt = GetStringValue(columnIndexMap, values, nameof(SendGridEventParquet.Attempt)),
				Type = GetStringValue(columnIndexMap, values, nameof(SendGridEventParquet.Type)),
				BounceClassification = GetStringValue(columnIndexMap, values, nameof(SendGridEventParquet.BounceClassification)),
				AsmGroupId = GetNullableInt32Value(columnIndexMap, values, nameof(SendGridEventParquet.AsmGroupId)),
				MarketingCampaignName = GetStringValue(columnIndexMap, values, nameof(SendGridEventParquet.MarketingCampaignName)),
				PoolId = GetNullableInt32Value(columnIndexMap, values, nameof(SendGridEventParquet.PoolId)),
				SendAt = GetNullableInt64Value(columnIndexMap, values, nameof(SendGridEventParquet.SendAt))
			};
		}

		return events;
	}

	private static Dictionary<string, int> BuildColumnIndexMap(IReadOnlyList<string> columns)
	{
		var map = new Dictionary<string, int>(columns.Count, StringComparer.OrdinalIgnoreCase);
		for (var i = 0; i < columns.Count; i++)
		{
			var column = columns[i];
			if (string.IsNullOrWhiteSpace(column) || map.ContainsKey(column))
			{
				continue;
			}

			map[column] = i;
		}

		return map;
	}

	private static string? GetStringValue(Dictionary<string, int> indexMap, IReadOnlyList<string> values, string columnName)
	{
		var raw = GetRawValue(indexMap, values, columnName);
		return string.IsNullOrWhiteSpace(raw) ? null : raw;
	}

	private static long GetInt64Value(Dictionary<string, int> indexMap, IReadOnlyList<string> values, string columnName)
	{
		var raw = GetRawValue(indexMap, values, columnName);
		return long.TryParse(raw, NumberStyles.Integer, CultureInfo.InvariantCulture, out var parsed) ? parsed : 0L;
	}

	private static long? GetNullableInt64Value(Dictionary<string, int> indexMap, IReadOnlyList<string> values, string columnName)
	{
		var raw = GetRawValue(indexMap, values, columnName);
		return long.TryParse(raw, NumberStyles.Integer, CultureInfo.InvariantCulture, out var parsed) ? parsed : null;
	}

	private static int? GetNullableInt32Value(Dictionary<string, int> indexMap, IReadOnlyList<string> values, string columnName)
	{
		var raw = GetRawValue(indexMap, values, columnName);
		return int.TryParse(raw, NumberStyles.Integer, CultureInfo.InvariantCulture, out var parsed) ? parsed : null;
	}

	private static string? GetRawValue(Dictionary<string, int> indexMap, IReadOnlyList<string> values, string columnName)
	{
		if (!indexMap.TryGetValue(columnName, out var index) || index < 0 || index >= values.Count)
		{
			return null;
		}

		return values[index];
	}

	<div class="table-responsive" @ref="_resultsHost"></div>

	@if (_hasSearched && _sendGridEvents.Length == 0)
	{
		<p>検索結果が見つかりませんでした。</p>
	}
}

<FluentDialog Hidden="@(!ShowEventDetailsDialog)" Modal="true" TrapFocus="true">
	<FluentDialogHeader>
		<FluentStack VerticalAlignment="VerticalAlignment.Center">
			<FluentLabel Typo="Typography.Header">イベント詳細</FluentLabel>
		</FluentStack>
	</FluentDialogHeader>
	<FluentDialogBody>
		@if (_selectedEvent != null)
		{
			<div style="max-height: 500px; overflow-y: auto;">
				<FluentStack Orientation="Orientation.Vertical" Style="gap: 10px;">
					<div><strong>Email:</strong> @_selectedEvent.Email</div>
					<div><strong>Timestamp:</strong> @ToJst(_selectedEvent.Timestamp).ToString("yyyy-MM-dd HH:mm:ss")</div>
					<div><strong>Event:</strong> @_selectedEvent.Event</div>
					@if (_selectedEvent.SendAt.HasValue)
					{
						<div><strong>Send At:</strong> @ToJst(_selectedEvent.SendAt.Value).ToString("yyyy-MM-dd HH:mm:ss")</div>
					}
					@if (!string.IsNullOrEmpty(_selectedEvent.Category))
					{
						<div><strong>Category:</strong> @_selectedEvent.Category</div>
					}
					@if (!string.IsNullOrEmpty(_selectedEvent.SgEventId))
					{
						<div><strong>SG Event ID:</strong> @_selectedEvent.SgEventId</div>
					}
					@if (!string.IsNullOrEmpty(_selectedEvent.SgMessageId))
					{
						<div><strong>SG Message ID:</strong> @_selectedEvent.SgMessageId</div>
					}
					@if (!string.IsNullOrEmpty(_selectedEvent.SgTemplateId))
					{
						<div><strong>SG Template ID:</strong> @_selectedEvent.SgTemplateId</div>
					}
					@if (!string.IsNullOrEmpty(_selectedEvent.UserAgent))
					{
						<div><strong>User Agent:</strong> @_selectedEvent.UserAgent</div>
					}
					@if (!string.IsNullOrEmpty(_selectedEvent.Ip))
					{
						<div><strong>IP Address:</strong> @_selectedEvent.Ip</div>
					}
					@if (!string.IsNullOrEmpty(_selectedEvent.Url))
					{
						<div><strong>URL:</strong> <a href="@_selectedEvent.Url" target="_blank">@_selectedEvent.Url</a></div>
					}
					@if (!string.IsNullOrEmpty(_selectedEvent.Reason))
					{
						<div><strong>Reason:</strong> @_selectedEvent.Reason</div>
					}
					@if (!string.IsNullOrEmpty(_selectedEvent.Status))
					{
						<div><strong>Status:</strong> @_selectedEvent.Status</div>
					}
					@if (!string.IsNullOrEmpty(_selectedEvent.Response))
					{
						<div><strong>Response:</strong> @_selectedEvent.Response</div>
					}
					@if (!string.IsNullOrEmpty(_selectedEvent.Attempt))
					{
						<div><strong>Attempt:</strong> @_selectedEvent.Attempt</div>
					}
					@if (!string.IsNullOrEmpty(_selectedEvent.Type))
					{
						<div><strong>Type:</strong> @_selectedEvent.Type</div>
					}
					@if (!string.IsNullOrEmpty(_selectedEvent.BounceClassification))
					{
						<div><strong>Bounce Classification:</strong> @_selectedEvent.BounceClassification</div>
					}
					@if (_selectedEvent.AsmGroupId.HasValue)
					{
						<div><strong>ASM Group ID:</strong> @_selectedEvent.AsmGroupId</div>
					}
					@if (!string.IsNullOrEmpty(_selectedEvent.MarketingCampaignName))
					{
						<div><strong>Marketing Campaign Name:</strong> @_selectedEvent.MarketingCampaignName</div>
					}
					@if (_selectedEvent.PoolId.HasValue)
					{
						<div><strong>Pool ID:</strong> @_selectedEvent.PoolId</div>
					}
				</FluentStack>
			</div>
		}
	</FluentDialogBody>
	<FluentDialogFooter>
		<FluentButton Appearance="Appearance.Neutral" @onclick="CloseEventDetailsDialog">閉じる</FluentButton>
	</FluentDialogFooter>
</FluentDialog>



